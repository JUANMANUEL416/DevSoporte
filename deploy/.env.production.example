# Producción — copie a backend\.env y ajuste valores reales.
APP_ENV=production
NODE_ENV=production
PORT=3300

PGHOST=localhost
PGPORT=5432
PGDATABASE=devsoporte
PGUSER=postgres
PGPASSWORD=cambie-esta-clave

JWT_SECRET=genere-un-secreto-largo-aleatorio
JWT_EXPIRES_IN=8h

# Misma URL pública donde acceden los usuarios (ngrok o dominio).
CORS_ORIGIN=https://su-dominio.ngrok-free.dev
PUBLIC_APP_URL=https://su-dominio.ngrok-free.dev
SIGNING_TOKEN_EXPIRES_DAYS=14
REGISTRO_TOKEN_EXPIRES_DAYS=365

SMTP_HOST=mail.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DevSoporte <no-reply@ejemplo.com>
