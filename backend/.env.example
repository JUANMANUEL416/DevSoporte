# Configuración del servidor
PORT=3300
NODE_ENV=development

# Entorno: development | pruebas | production
# APP_ENV=development

# Conexión a PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=devsoporte
PGUSER=postgres
PGPASSWORD=cambie-esta-clave

# Seguridad
JWT_SECRET=genere-un-secreto-largo-aleatorio
JWT_EXPIRES_IN=8h

# CORS (origen del frontend Quasar; varios separados por coma para ngrok)
# Ejemplo: CORS_ORIGIN=http://localhost:9020,https://xxxx.ngrok-free.app
CORS_ORIGIN=http://localhost:9020

# URL pública del frontend (enlaces de firma por correo)
PUBLIC_APP_URL=http://localhost:9020
SIGNING_TOKEN_EXPIRES_DAYS=14
REGISTRO_TOKEN_EXPIRES_DAYS=365

# ngrok en producción (PM2 levanta el túnel con npm run deploy)
NGROK_AUTOSTART=true
NGROK_DOMAIN=crested-gently-landowner.ngrok-free.dev

# Correo (opcional)
SMTP_HOST=mail.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@ejemplo.com
SMTP_PASS=clave-o-app-password
SMTP_FROM=DevSoporte <soporte@ejemplo.com>

# Cuentas de cobro VIP — remitente distinto al de soporte/bitácora
SMTP_FROM_CXC=JoseManuel <josemanuel_416@hotmail.com>
# Opcional: buzón SMTP propio para CXC (si no se define, usa SMTP_* con SMTP_FROM_CXC)
# SMTP_CXC_HOST=mail.ejemplo.com
# SMTP_CXC_PORT=587
# SMTP_CXC_SECURE=false
# SMTP_CXC_USER=cuentas@ejemplo.com
# SMTP_CXC_PASS=clave-cuentas

# Copia en carpeta Enviados del buzón (IMAP)
SMTP_SAVE_SENT_COPY=true
IMAP_HOST=mail.ejemplo.com
IMAP_PORT=993
IMAP_SECURE=true
# IMAP_USER e IMAP_PASS: opcional; por defecto usa SMTP_USER / SMTP_PASS
# IMAP_SENT_FOLDER=INBOX.Sent

# Logo del PDF de capacitaciones (opcional)
CAPACITACION_LOGO_PATH=
