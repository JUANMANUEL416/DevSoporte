# Configuración del servidor
PORT=3300
NODE_ENV=development

# Conexión a PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=devsoporte
PGUSER=postgres
PGPASSWORD=cambie-esta-clave

# Seguridad
JWT_SECRET=cambie-este-secreto-en-produccion
JWT_EXPIRES_IN=8h

# CORS (origen del frontend Quasar; varios separados por coma para ngrok)
# Ejemplo con ngrok: CORS_ORIGIN=http://localhost:9020,https://xxxx.ngrok-free.app
CORS_ORIGIN=http://localhost:9020

# URL pública del frontend (enlaces de firma por correo).
# En local sin ngrok: http://localhost:9020
# Con ngrok: copie la URL https://....ngrok-free.app y reinicie el backend.
# IMPORTANTE: cada vez que reinicia ngrok la URL cambia (salvo dominio reservado).
PUBLIC_APP_URL=http://localhost:9020
SIGNING_TOKEN_EXPIRES_DAYS=14
REGISTRO_TOKEN_EXPIRES_DAYS=365

# Correo (opcional — si no se configura, las capacitaciones se guardan sin enviar email)
SMTP_HOST=mail.ixcolombia.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@ejemplo.com
SMTP_PASS=clave-o-app-password
SMTP_FROM=DevSoporte <usuario@ejemplo.com>

# Logo del PDF de capacitaciones (opcional; por defecto backend/assets/reports/logo-ixcalidad.jpg)
CAPACITACION_LOGO_PATH=
