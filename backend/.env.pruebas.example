# Entorno de PRUEBAS — copie a backend\.env.pruebas
APP_ENV=pruebas
NODE_ENV=development
# Puerto distinto a producción (PM2 usa 3300) para correr ambos a la vez
PORT=3301

# Base de datos dedicada (separada de producción/desarrollo)
PGHOST=localhost
PGPORT=5432
PGDATABASE=devsoporte_pruebas
PGUSER=postgres
PGPASSWORD=cambie-esta-clave

JWT_SECRET=secreto-solo-para-pruebas-no-usar-en-produccion
JWT_EXPIRES_IN=8h

# Frontend de pruebas en puerto 9021 (producción/PM2 sigue en 3300)
CORS_ORIGIN=http://localhost:9021
PUBLIC_APP_URL=http://localhost:9021
SIGNING_TOKEN_EXPIRES_DAYS=14
REGISTRO_TOKEN_EXPIRES_DAYS=365

# Correo: dejar vacío para no enviar mails reales en pruebas
# SMTP_HOST=
# SMTP_USER=
# SMTP_FROM=soporte@ejemplo.com
# SMTP_FROM_CXC=cuentas@ejemplo.com
# Si configura SMTP, los asuntos llevan prefijo [PRUEBAS]
